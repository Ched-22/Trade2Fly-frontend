# Browser calls /api → Vite proxies to the Nest backend (see vite.config.js).
# You MUST run the backend on port 3000, OR change the proxy target below.
#
# Easiest: from repo root (parent of frontend/), run:
#   npm install
#   npm run dev
# That starts Nest + Vite together.
#
# Optional: backend URL for the dev proxy (default http://127.0.0.1:3000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
#
# Optional: force direct API URL in the browser (cross-origin; set backend CORS)
# VITE_API_URL=http://127.0.0.1:3000/api
